<h1><%= @place.name %></h1>

<h2>Entries</h2>
<ul>
  <% for entry in @entries %>
    <li>
      <strong><%= entry.title %></strong> 
      (<%= entry.occurred_on %>) - 
      <%= entry.description %>
    </li>
  <% end %>
</ul>

<p>
  <a href="/entries/new?place_id=<%= @place.id %>">New Entry</a>
</p>

<p>
  <a href="/places">Back to all places</a>
</p>